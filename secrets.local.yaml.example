# Скопируйте в secrets.local.yaml (файл в .gitignore)

# ERP — только чтение остатков
db:
  host: erp.shinaufa.ru
  port: 5432
  database: alpha
  user: shinaufa
  password: your_erp_password

# Описания Avito — локальный файл (Docker не нужен)
descriptions_db:
  engine: sqlite
  path: data/avito_descriptions.db

# Альтернатива: отдельный PostgreSQL (engine: postgres + host/port/...)
# descriptions_db:
#   engine: postgres
#   host: 127.0.0.1
#   port: 5432
#   database: avito
#   user: avito
#   password: avito

yandex_disk:
  oauth_token: your_yandex_disk_token

# Avito Business API (ЛК → Для профессионалов → API)
avito:
  client_id: your_client_id
  client_secret: your_client_secret
  # api_base: https://api.avito.ru

deepseek:
  api_key: sk-...
  base_url: https://api.deepseek.com
  model: deepseek-chat

# Пароли для https://avito.shinaufa.ru/photo/ (логин = выбор магазина md/pg)
photo_upload:
  session_secret: change-me-to-long-random-string
  stores:
    md: your-md-password
    pg: your-pg-password
  # Первый админ (создаётся в БД при старте, если ещё нет)
  admin:
    login: admin
    password: change-me-admin-password
    display_name: Админ
